{
  "name": "cf-asset-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local --port 8787",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "types": "wrangler types src/worker-configuration.d.ts",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply cf-asset-hub-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply cf-asset-hub-db --remote",
    "check": "npm run typecheck && npm test"
  },
  "dependencies": {
    "hono": "^4.8.4",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.20",
    "@types/node": "^26.0.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.21.2"
  }
}
